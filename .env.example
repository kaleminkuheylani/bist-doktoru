# CollectAPI — BİRİNCİL KAYNAK (hisseler, borsa, döviz, altın)
# https://collectapi.com/tr/api/economy/altin-doviz-ve-borsa-api
# Token'ı olduğu gibi yaz — "apikey" prefix EKLEME, sunucu otomatik ekler
COLLECTAPI_KEY=YOUR_COLLECTAPI_KEY_HERE

# Twelve Data — YEDEK KAYNAK (CollectAPI çalışmazsa devreye girer)
# https://twelvedata.com — ücretsiz plan: 800 kredi/gün, 8 kredi/dakika
TWELVE_DATA_KEY=YOUR_TWELVE_DATA_KEY_HERE

# Next.js port (opsiyonel, varsayılan: 3000)
PORT=3000
